---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/shared/Nav.astro';
import Footer from '../components/shared/Footer.astro';
const base = import.meta.env.BASE_URL;

const features = [
  {
    num: '01',
    title: 'Merge',
    desc: 'Combine multiple PDF files into a single document.',
    details: [
      'Drag-and-drop file ordering',
      'Unlimited file count',
      'Preserves formatting and links',
    ],
  },
  {
    num: '02',
    title: 'Split',
    desc: 'Extract specific pages or split into separate files.',
    details: ['Page range selection', 'Single page extraction', 'Batch splitting'],
  },
  {
    num: '03',
    title: 'Reorder',
    desc: 'Drag and drop pages to arrange them in any order.',
    details: ['Visual page thumbnails', 'Drag-and-drop interface', 'Instant preview'],
  },
  {
    num: '04',
    title: 'Rotate',
    desc: 'Rotate any page to the correct orientation.',
    details: [
      '90, 180, or 270 degree rotation',
      'Per-page or bulk rotation',
      'Visual confirmation',
    ],
  },
  {
    num: '05',
    title: 'Delete',
    desc: 'Remove unwanted pages cleanly from any PDF.',
    details: ['Click to select pages', 'Bulk deletion', 'Undo support'],
  },
  {
    num: '06',
    title: 'Compress',
    desc: 'Reduce PDF file size for easier sharing.',
    details: ['Optimized output', 'Quality preservation', 'Fast processing'],
  },
  {
    num: '07',
    title: 'Watermark',
    desc: 'Add text or image watermarks to your documents.',
    details: ['Custom text watermarks', 'Adjustable opacity', 'Position control'],
  },
  {
    num: '08',
    title: 'Convert',
    desc: 'Convert between PDF and image formats.',
    details: ['PDF to images', 'Images to PDF', 'Multiple format support'],
  },
];
---

<Layout title="Features — Pasta">
  <Fragment slot="head">
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Work+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div class="font-body bg-white text-primary min-h-screen">
    <Nav base={base} currentPage="features" />

    <section class="px-6 md:px-16 lg:px-24 pt-24 pb-16 border-b border-border">
      <div class="max-w-7xl mx-auto">
        <p class="text-xs font-light text-muted uppercase tracking-[0.2em] mb-4">Product</p>
        <h1 class="font-display text-[clamp(3rem,7vw,6rem)] leading-[0.9] text-primary">
          Everything<br />you need.
        </h1>
      </div>
    </section>

    <section class="px-6 md:px-16 lg:px-24 py-16">
      <div class="max-w-7xl mx-auto">
        <div class="border-t-2 border-primary">
          {
            features.map((f, i) => (
              <div
                class:list={[
                  'grid grid-cols-[3rem_1fr] md:grid-cols-[3rem_8rem_1fr] gap-4 py-8 border-b',
                  i === features.length - 1 ? 'border-primary border-b-2' : 'border-border',
                ]}
              >
                <span class="text-xs text-muted">{f.num}</span>
                <h3
                  class:list={[
                    'font-display text-2xl text-primary',
                    i === features.length - 1 && 'text-accent',
                  ]}
                >
                  {f.title}
                </h3>
                <div class="col-span-full md:col-auto">
                  <p class="font-light text-body leading-relaxed">{f.desc}</p>
                  <ul class="mt-3 space-y-1">
                    {f.details.map((d) => (
                      <li class="text-sm text-muted font-light">{d}</li>
                    ))}
                  </ul>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="px-6 md:px-16 lg:px-24 py-16">
      <div class="max-w-7xl mx-auto border-l-4 border-accent pl-6">
        <p class="text-sm font-light text-body leading-relaxed max-w-2xl">
          Every operation runs entirely in your browser. No files are uploaded to any server. Your
          documents never leave your device.
        </p>
      </div>
    </section>

    <section class="px-6 md:px-16 lg:px-24 py-20">
      <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-[2fr_1fr] gap-8 items-end">
        <h2 class="font-display text-[clamp(3rem,7vw,5rem)] leading-[0.9] text-primary">
          Try it<br />now.
        </h2>
        <div>
          <a
            href={`${base}app`}
            class="inline-block px-8 py-4 bg-accent text-white text-xs font-semibold uppercase tracking-[0.15em] no-underline hover:bg-primary transition-colors"
          >
            Open Editor
          </a>
        </div>
      </div>
    </section>

    <Footer base={base} />
  </div>
</Layout>
