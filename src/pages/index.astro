---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/shared/Nav.astro';
import Footer from '../components/shared/Footer.astro';
import { contentSlide } from '../utils/transitions';

const base = import.meta.env.BASE_URL;
---

<Layout
  title="Pasta - Client-Side PDF Editor"
  description="Edit, merge, split, reorder, rotate, and delete PDF files entirely in your browser. No uploads, no servers, no privacy compromises."
>
  <div class="page" transition:animate={contentSlide}>
    <Nav base={base} currentPage="home" />
    <section class="hero">
      <div class="hero-grid">
        <div class="hero-left">
          <p class="hero-label">Client-side PDF editor</p>
          <h1 class="hero-title">Pasta</h1>
          <div class="hero-tagline">
            <span class="red-bar"></span>
            <p class="hero-tagline-text">Edit, merge, split — all in your browser.</p>
          </div>
        </div>
        <div class="hero-right">
          <div class="hero-right-inner">
            <p class="hero-right-text">
              No file uploads. No server processing. Every operation runs entirely in your browser.
              Your documents stay private.
            </p>
            <a href={`${base}app`} class="cta-underline">Open Editor</a>
          </div>
        </div>
      </div>
    </section>

    <section class="features">
      <div class="features-inner">
        <div class="features-header animate-on-scroll">
          <h2 class="features-title">Features</h2>
          <p class="features-subtitle">Five core operations, zero compromises.</p>
        </div>

        <div class="feature-list">
          {
            [
              {
                num: '01',
                title: 'Merge',
                text: 'Combine multiple PDF files into one cohesive document.',
                accent: false,
              },
              {
                num: '02',
                title: 'Split',
                text: 'Extract specific pages into separate PDF files.',
                accent: false,
              },
              {
                num: '03',
                title: 'Reorder',
                text: 'Drag and drop pages to arrange them in any order you need.',
                accent: false,
              },
              {
                num: '04',
                title: 'Rotate',
                text: 'Rotate any page to 90, 180, or 270 degrees.',
                accent: false,
              },
              {
                num: '05',
                title: 'Delete',
                text: 'Remove unwanted pages cleanly from any PDF.',
                accent: true,
              },
            ].map((f, i) => (
              <div
                class:list={[
                  'feature-row animate-on-scroll',
                  { 'feature-row-last': f.accent },
                  `stagger-${Math.min(i + 1, 8)}`,
                ]}
              >
                <span class="feature-num">{f.num}</span>
                <h3 class:list={['feature-name', { 'feature-name-red': f.accent }]}>{f.title}</h3>
                <p class="feature-desc">{f.text}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section class="bottom-cta animate-on-scroll">
      <div class="bottom-cta-inner">
        <h2 class="bottom-title">Start<br />editing.</h2>
        <div class="bottom-action">
          <a href={`${base}app`} class="cta-filled press-feedback">Launch Pasta</a>
        </div>
      </div>
    </section>

    <Footer base={base} />
  </div>
</Layout>

<style>
  .page {
    font-family: 'Work Sans', sans-serif;
    background-color: #ffffff;
    color: #111;
    min-height: 100vh;
  }

  /* Hero entrance animations */
  .hero-label {
    animation: slideUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.1s both;
  }

  .hero-title {
    animation: slideUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.2s both;
  }

  .hero-tagline {
    animation: slideUp 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.3s both;
  }

  .hero-right-inner {
    animation: fadeIn 0.5s cubic-bezier(0.22, 1, 0.36, 1) 0.4s both;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-label,
    .hero-title,
    .hero-tagline,
    .hero-right-inner {
      animation: none;
    }
  }

  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 4rem 1.5rem;
  }

  @media (min-width: 768px) {
    .hero {
      padding: 4rem 4rem;
    }
  }
  @media (min-width: 1024px) {
    .hero {
      padding: 4rem 6rem;
    }
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    max-width: 80rem;
    margin: 0 auto;
    width: 100%;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 2fr 1fr;
      gap: 2rem;
    }
  }

  .hero-label {
    font-size: 0.8rem;
    font-weight: 300;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(5rem, 12vw, 10rem);
    line-height: 0.85;
    color: #111;
    letter-spacing: -0.01em;
  }

  .hero-tagline {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .red-bar {
    display: block;
    width: 3rem;
    height: 4px;
    background-color: #ff0000;
    flex-shrink: 0;
  }

  .hero-tagline-text {
    font-size: 1.05rem;
    font-weight: 300;
    color: #888;
  }

  .hero-right {
    display: flex;
    justify-content: flex-end;
  }

  .hero-right-inner {
    border-left: 4px solid #ff0000;
    padding-left: 1.5rem;
    max-width: 20rem;
  }

  .hero-right-text {
    font-size: 0.95rem;
    color: #555;
    line-height: 1.7;
  }

  .cta-underline {
    display: inline-block;
    margin-top: 1.5rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: #111;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    text-decoration: none;
    border-bottom: 2px solid #111;
    padding-bottom: 4px;
    transition:
      color 0.2s,
      border-color 0.2s;
  }

  .cta-underline:hover {
    color: #ff0000;
    border-color: #ff0000;
  }

  /* Features */
  .features {
    border-top: 1px solid #ddd;
    padding: 6rem 1.5rem;
  }

  @media (min-width: 768px) {
    .features {
      padding: 6rem 4rem;
    }
  }
  @media (min-width: 1024px) {
    .features {
      padding: 6rem;
    }
  }

  .features-inner {
    max-width: 80rem;
    margin: 0 auto;
  }

  .features-header {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 4rem;
  }

  @media (min-width: 1024px) {
    .features-header {
      grid-template-columns: 1fr 2fr;
      align-items: end;
    }
  }

  .features-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    color: #111;
  }

  .features-subtitle {
    font-weight: 300;
    color: #888;
  }

  .feature-list {
    border-top: 2px solid #111;
  }

  .feature-row {
    display: grid;
    grid-template-columns: 3rem 1fr;
    gap: 1rem;
    padding: 2rem 0;
    border-bottom: 1px solid #ddd;
    align-items: baseline;
  }

  @media (min-width: 768px) {
    .feature-row {
      grid-template-columns: 3rem 8rem 1fr;
    }
    .feature-desc {
      grid-column: auto;
    }
  }

  .feature-row-last {
    border-bottom: 2px solid #111;
  }

  .feature-num {
    font-size: 0.75rem;
    color: #888;
  }

  .feature-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.75rem;
    color: #111;
  }

  .feature-name-red {
    color: #ff0000;
  }

  .feature-desc {
    grid-column: 1 / -1;
    font-weight: 300;
    color: #555;
    line-height: 1.6;
  }

  /* Bottom CTA */
  .bottom-cta {
    padding: 8rem 1.5rem;
  }

  @media (min-width: 768px) {
    .bottom-cta {
      padding: 8rem 4rem;
    }
  }
  @media (min-width: 1024px) {
    .bottom-cta {
      padding: 8rem 6rem;
    }
  }

  .bottom-cta-inner {
    max-width: 80rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: end;
  }

  @media (min-width: 1024px) {
    .bottom-cta-inner {
      grid-template-columns: 2fr 1fr;
    }
  }

  .bottom-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(3.5rem, 8vw, 6rem);
    color: #111;
    line-height: 0.9;
  }

  .bottom-action {
    display: flex;
    align-items: flex-end;
  }

  .cta-filled {
    display: inline-block;
    padding: 1.25rem 3rem;
    background-color: #ff0000;
    color: white;
    font-family: 'Work Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    text-decoration: none;
    transition: background-color 0.2s;
  }

  .cta-filled:hover {
    background-color: #111;
  }
</style>
