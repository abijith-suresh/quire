---
import Layout from "../layouts/Layout.astro";

const base = import.meta.env.BASE_URL;
---

<Layout
  title="Pasta — Editor"
  description="Open your PDF and start editing. Merge, split, reorder, rotate, and delete pages — all client-side, nothing leaves your device."
>
  <div
    data-page="editor"
    class="font-['Work_Sans',sans-serif] bg-white text-[#111] h-dvh flex flex-col overflow-hidden"
    transition:animate="none"
  >
    <!-- Dark Header -->
    <header id="toolbar" class="bg-[#111] text-white h-14 flex items-center px-6 flex-shrink-0">
      <a
        href={base}
        class="font-['Bebas_Neue',sans-serif] text-2xl tracking-wide text-white no-underline"
        >Pasta</a
      >
      <span class="w-px h-6 bg-[#555] mx-5"></span>
      <span id="editor-page-count" class="text-sm text-[#888]"></span>
      <span class="flex-1"></span>
      <span id="selection-info" class="text-sm text-[#888]"></span>
      <span class="w-px h-6 bg-[#555] mx-5"></span>
      <a href={base} class="text-sm text-[#888] hover:text-white no-underline transition-colors"
        >&#8592; Back</a
      >
    </header>

    <!-- Uploader Section — full-page centered upload -->
    <div id="uploader-section" class="flex-1 flex items-center justify-center min-h-0">
      <div class="w-full max-w-lg px-6">
        <div
          id="drop-zone"
          role="button"
          tabindex="0"
          aria-label="Click or drag a PDF file here to upload"
          class="border-2 border-dashed border-[#ddd] hover:border-[#111] transition-colors py-20 text-center cursor-pointer"
        >
          <p class="font-['Bebas_Neue',sans-serif] text-4xl text-[#111] mb-2">Drop PDF here</p>
          <p class="text-[11px] uppercase tracking-[0.15em] text-[#888]">or click to browse</p>
        </div>
        <input type="file" id="file-input" accept="application/pdf" class="hidden" />
        <p
          id="error-message"
          role="alert"
          class="text-[#ff0000] text-xs mt-3 text-center"
          style="visibility: hidden; height: 0; overflow: hidden;"
        >
        </p>
      </div>
    </div>

    <!-- Editor Section — hidden initially, shown on PDF load -->
    <div id="editor-section" class="min-h-0" style="display: none;">
      <div class="flex h-[calc(100dvh-3.5rem)]">
        <!-- Sidebar -->
        <aside class="w-56 border-r border-[#ddd] flex-col flex-shrink-0 hidden md:flex">
          <div class="flex-1 overflow-y-auto min-h-0">
            <!-- Upload -->
            <div class="p-4 border-b border-[#ddd]">
              <p class="text-[11px] uppercase tracking-wider text-[#888] mb-2">Upload</p>
              <button
                id="btn-add-pdf"
                class="w-full border border-dashed border-[#ddd] hover:border-[#111] transition-colors py-6 text-center cursor-pointer bg-transparent"
              >
                <span class="text-[11px] text-[#888] uppercase tracking-wider">+ Add PDF</span>
              </button>
            </div>

            <!-- Selection -->
            <div class="p-4 border-b border-[#ddd]">
              <p class="text-[11px] uppercase tracking-wider text-[#888] mb-3">Selection</p>
              <button
                id="btn-select-all"
                aria-label="Select all pages"
                class="w-full text-left text-xs text-[#555] hover:text-[#111] hover:bg-[#f5f5f5] bg-transparent border-none cursor-pointer py-2 px-2 transition-colors"
                >Select All</button
              >
            </div>

            <!-- Actions -->
            <div class="p-4 border-b border-[#ddd]">
              <p class="text-[11px] uppercase tracking-wider text-[#888] mb-3">Actions</p>
              <button
                id="btn-rotate"
                aria-label="Rotate selected pages 90 degrees"
                class="w-full text-left text-xs text-[#555] hover:text-[#111] hover:bg-[#f5f5f5] bg-transparent border-none cursor-pointer py-2 px-2 transition-colors"
                >Rotate</button
              >
              <button
                id="btn-delete"
                aria-label="Mark selected pages for deletion"
                class="w-full text-left text-xs text-[#ff0000] hover:bg-[#fff5f5] bg-transparent border-none cursor-pointer py-2 px-2 transition-colors"
                >Delete</button
              >
              <button
                id="btn-extract"
                aria-label="Extract selected pages to a new PDF"
                class="w-full text-left text-xs text-[#555] hover:text-[#111] hover:bg-[#f5f5f5] bg-transparent border-none cursor-pointer py-2 px-2 transition-colors"
                >Extract</button
              >
            </div>
          </div>

          <!-- Export — pinned to bottom -->
          <div class="p-4 border-t border-[#ddd] flex-shrink-0">
            <p class="text-[11px] uppercase tracking-wider text-[#888] mb-3">Export</p>
            <button
              id="btn-download"
              class="w-full bg-[#ff0000] text-white text-[11px] uppercase tracking-[0.15em] font-semibold py-3 border-none cursor-pointer hover:bg-[#111] transition-colors"
              >Download</button
            >
          </div>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 flex flex-col min-h-0">
          <!-- Dense Page Grid — only this scrolls -->
          <div class="flex-1 overflow-y-auto p-4">
            <div
              id="pages-grid"
              role="listbox"
              aria-multiselectable="true"
              aria-label="PDF pages"
              class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-7 gap-3"
            >
            </div>
          </div>

          <!-- Mobile toolbar -->
          <div
            class="md:hidden border-t border-[#ddd] p-2.5 flex items-center gap-2 flex-wrap justify-center"
          >
            <button
              onclick="document.getElementById('btn-select-all')?.click()"
              class="text-[11px] uppercase tracking-wider text-[#555] bg-transparent border border-[#ddd] px-3 py-1.5 cursor-pointer"
              >Select All</button
            >
            <button
              onclick="document.getElementById('btn-rotate')?.click()"
              class="text-[11px] uppercase tracking-wider text-[#555] bg-transparent border border-[#ddd] px-3 py-1.5 cursor-pointer"
              >Rotate</button
            >
            <button
              onclick="document.getElementById('btn-delete')?.click()"
              class="text-[11px] uppercase tracking-wider text-[#ff0000] bg-transparent border border-[#ddd] px-3 py-1.5 cursor-pointer"
              >Delete</button
            >
            <button
              onclick="document.getElementById('btn-add-pdf')?.click()"
              class="text-[11px] uppercase tracking-wider text-[#555] bg-transparent border border-[#ddd] px-3 py-1.5 cursor-pointer"
              >Add PDF</button
            >
            <button
              onclick="document.getElementById('btn-extract')?.click()"
              class="text-[11px] uppercase tracking-wider text-[#555] bg-transparent border border-[#ddd] px-3 py-1.5 cursor-pointer"
              >Extract</button
            >
            <button
              onclick="document.getElementById('btn-download')?.click()"
              class="text-[11px] uppercase tracking-wider bg-[#ff0000] text-white border-none px-4 py-1.5 cursor-pointer"
              >Download</button
            >
          </div>

          <!-- Status Bar -->
          <div
            role="status"
            aria-live="polite"
            aria-atomic="true"
            class="h-8 bg-[#f5f5f5] border-t border-[#ddd] flex items-center px-5 text-[11px] text-[#888] flex-shrink-0"
          >
            <span id="status-page-count"></span>
            <span class="flex-1 text-center" id="status-selection"></span>
            <span class="flex items-center gap-1.5">
              <span class="w-1.5 h-1.5 bg-[#ff0000] inline-block"></span>
              Ready
            </span>
          </div>
        </main>
      </div>
    </div>

    <input type="file" id="add-pdf-input" accept="application/pdf" class="hidden" />
  </div>
</Layout>

<script>
  import { EditorController } from "../controllers/editor-controller";
  import { PDFUploaderController } from "../controllers/pdf-uploader-controller";
  import { pdfService } from "../services/pdf-service";
  import { pdfOperationsService } from "../services/pdf-operations-service";

  let abortController = new AbortController();

  function initialize() {
    if (!document.getElementById("pages-grid")) return;

    abortController.abort();
    abortController = new AbortController();

    try {
      new PDFUploaderController("drop-zone", "file-input", "error-message", pdfService);
      new EditorController(
        "pages-grid",
        "toolbar",
        "uploader-section",
        "editor-section",
        "add-pdf-input",
        pdfService,
        pdfOperationsService,
        abortController.signal
      );
    } catch (error) {
      console.error("Failed to initialize:", error);
    }
  }

  document.addEventListener("astro:page-load", initialize);
</script>

<style is:global>
  body:has([data-page="editor"]) {
    margin: 0;
    padding: 0;
    height: 100%;
    overflow: hidden;
  }

  /* When controller sets display:block, this ensures it fills the flex column */
  #editor-section[style*="block"] {
    flex: 1;
    min-height: 0;
  }

  /* Page thumbnails — Swiss industrial style */
  .editor-page {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    background: #fff;
    cursor: pointer;
    user-select: none;
  }

  .editor-page.selected {
    ring: 2px solid #ff0000;
  }

  .editor-page.selected {
    outline: 2px solid #ff0000;
    outline-offset: 2px;
  }

  .editor-page.selected::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 6px;
    height: 6px;
    background: #ff0000;
    z-index: 1;
  }

  .editor-page.marked-deleted {
    opacity: 0.4;
  }

  .editor-page.marked-deleted::after {
    content: "DELETED";
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(255, 255, 255, 0.6);
    color: #ff0000;
    font-size: 8px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 2px 6px;
    pointer-events: none;
    z-index: 1;
  }

  .editor-page.dragging {
    opacity: 0.3;
    cursor: grabbing;
  }

  /* Directional insertion indicator — shows where the dropped page will land */
  .editor-page.drag-insert-before {
    box-shadow: -3px 0 0 0 #ff0000;
  }

  .editor-page.drag-insert-after {
    box-shadow: 3px 0 0 0 #ff0000;
  }

  .canvas-container {
    aspect-ratio: 3 / 4;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #ddd;
    transition: border-color 0.2s;
  }

  /* Placeholder shown while the canvas has not yet been painted */
  .canvas-container.thumbnail-placeholder {
    background: #f0f0f0;
  }

  .editor-page:hover .canvas-container {
    border-color: #111;
  }

  .editor-page .page-canvas {
    max-width: 100%;
    max-height: 100%;
  }

  .page-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    margin-top: 4px;
    padding: 0;
  }

  .page-controls .page-label {
    font-size: 9px;
    color: #888;
  }

  .btn-page-rotate {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 10px;
    padding: 0;
    color: #ddd;
    opacity: 0;
    transition:
      opacity 0.2s,
      color 0.2s;
  }

  .editor-page:hover .btn-page-rotate {
    opacity: 1;
  }

  .btn-page-rotate:hover {
    color: #888;
  }

  /* Drop zone drag-over state */
  #drop-zone.drag-over {
    border-color: #111;
    background: #f5f5f5;
  }
</style>
