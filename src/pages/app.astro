---
import Layout from "../layouts/Layout.astro";
import Editor from "../components/app/Editor";
---

<Layout
  title="Quire — Editor"
  description="Open your PDF and start editing. Merge, split, reorder, rotate, and delete pages — all client-side, nothing leaves your device."
>
  <div data-page="editor" transition:animate="none">
    <Editor client:only="solid-js" />
  </div>
</Layout>

<style is:global>
  body:has([data-page="editor"]) {
    margin: 0;
    padding: 0;
    height: 100%;
    overflow: hidden;
  }

  /* Page thumbnails — Swiss industrial style */
  .editor-page {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    background: #fff;
    cursor: pointer;
    user-select: none;
  }

  .editor-page.selected {
    ring: 2px solid #ff0000;
  }

  .editor-page.selected {
    outline: 2px solid #ff0000;
    outline-offset: 2px;
  }

  .editor-page.selected::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 6px;
    height: 6px;
    background: #ff0000;
    z-index: 1;
  }

  .editor-page.marked-deleted {
    opacity: 0.4;
  }

  .editor-page.marked-deleted::after {
    content: "DELETED";
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: rgba(255, 255, 255, 0.6);
    color: #ff0000;
    font-size: 8px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 2px 6px;
    pointer-events: none;
    z-index: 1;
  }

  .editor-page.dragging {
    opacity: 0.3;
    cursor: grabbing;
  }

  /* Directional insertion indicator — shows where the dropped page will land */
  .editor-page.drag-insert-before {
    box-shadow: -3px 0 0 0 #ff0000;
  }

  .editor-page.drag-insert-after {
    box-shadow: 3px 0 0 0 #ff0000;
  }

  .canvas-container {
    aspect-ratio: 3 / 4;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #ddd;
    transition: border-color 0.2s;
  }

  /* Placeholder shown while the canvas has not yet been painted */
  .canvas-container.thumbnail-placeholder {
    background: #f0f0f0;
  }

  .editor-page:hover .canvas-container {
    border-color: #111;
  }

  .editor-page .page-canvas {
    max-width: 100%;
    max-height: 100%;
  }

  .page-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    margin-top: 4px;
    padding: 0;
  }

  .page-controls .page-label {
    font-size: 9px;
    color: #888;
  }

  .btn-page-rotate {
    background: none;
    border: none;
    cursor: pointer;
    font-size: 10px;
    padding: 0;
    color: #ddd;
    opacity: 0;
    transition:
      opacity 0.2s,
      color 0.2s;
  }

  .editor-page:hover .btn-page-rotate {
    opacity: 1;
  }

  .btn-page-rotate:hover {
    color: #888;
  }

  /* Drop zone drag-over state */
  #drop-zone.drag-over {
    border-color: #111;
    background: #f5f5f5;
  }
</style>
