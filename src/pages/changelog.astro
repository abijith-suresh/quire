---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/shared/Nav.astro';
import Footer from '../components/shared/Footer.astro';
import { contentSlide } from '../utils/transitions';
const base = import.meta.env.BASE_URL;

const versions = [
  {
    version: 'v1.0',
    date: 'February 2026',
    changes: [
      'Added watermark and convert operations',
      'New SEO pages: features, about, blog, privacy, terms, FAQ',
      'Shared navigation and footer components',
      'Mobile rendering fixes for feature grid',
      'Tailwind CSS theme tokens for design consistency',
    ],
  },
  {
    version: 'v0.9',
    date: 'January 2026',
    changes: [
      'Redesigned editor with Swiss modernist style',
      'New landing page with Bebas Neue typography',
      'Improved page thumbnail rendering',
      'Added compress operation',
    ],
  },
  {
    version: 'v0.8',
    date: 'December 2025',
    changes: [
      'Initial release with core PDF operations',
      'Merge, split, reorder, rotate, and delete',
      'Drag-and-drop file upload',
      'Client-side processing with pdf-lib',
    ],
  },
];
---

<Layout title="Changelog — Pasta">
  <div class="font-body bg-white text-primary min-h-screen" transition:animate={contentSlide}>
    <Nav base={base} />

    <section class="px-6 md:px-16 lg:px-24 pt-24 pb-16 border-b border-border">
      <div class="max-w-7xl mx-auto">
        <p class="text-xs font-light text-muted uppercase tracking-[0.2em] mb-4 animate-on-scroll">
          History
        </p>
        <h1
          class="font-display text-[clamp(3rem,7vw,6rem)] leading-[0.9] text-primary animate-on-scroll stagger-1"
        >
          Changelog.
        </h1>
      </div>
    </section>

    <section class="px-6 md:px-16 lg:px-24 py-16">
      <div class="max-w-7xl mx-auto border-t-2 border-primary">
        {
          versions.map((v, i) => (
            <div
              class:list={[
                'grid grid-cols-1 md:grid-cols-[10rem_1fr] gap-4 md:gap-8 py-8 border-b animate-on-scroll',
                i === versions.length - 1 ? 'border-primary border-b-2' : 'border-border',
                `stagger-${Math.min(i + 1, 8)}`,
              ]}
            >
              <div>
                <p class="font-display text-2xl text-primary">{v.version}</p>
                <p class="text-xs text-muted font-light mt-1">{v.date}</p>
              </div>
              <ul class="space-y-2">
                {v.changes.map((c) => (
                  <li class="text-body font-light leading-relaxed">{c}</li>
                ))}
              </ul>
            </div>
          ))
        }
      </div>
    </section>

    <Footer base={base} />
  </div>
</Layout>
