---
import changelogSource from "../../CHANGELOG.md?raw";
import Layout from "../layouts/Layout.astro";
import Nav from "../components/shared/Nav.astro";
import Footer from "../components/shared/Footer.astro";
import { contentSlide } from "../utils/transitions";

const base = import.meta.env.BASE_URL;

type ReleaseSection = { title: string; items: string[] };
type Release = { version: string; date: string; sections: ReleaseSection[] };

function parseChangelog(source: string): Release[] {
  const releases: Release[] = [];
  const releaseMatches = [
    ...source.matchAll(/^## \[(?!Unreleased)([^\]]+)\] - (\d{4}-\d{2}-\d{2})$/gm),
  ];

  for (const [index, match] of releaseMatches.entries()) {
    const [, version, date] = match;
    const start = (match.index ?? 0) + match[0].length + 1;
    const end =
      index + 1 < releaseMatches.length
        ? (releaseMatches[index + 1].index ?? source.length)
        : source.length;
    const body = source.slice(start, end).trim();
    const sections: ReleaseSection[] = [];
    const sectionMatches = [...body.matchAll(/^### ([^\n]+)$/gm)];

    for (const [sectionIndex, sectionMatch] of sectionMatches.entries()) {
      const [, title] = sectionMatch;
      const sectionStart = (sectionMatch.index ?? 0) + sectionMatch[0].length + 1;
      const sectionEnd =
        sectionIndex + 1 < sectionMatches.length
          ? (sectionMatches[sectionIndex + 1].index ?? body.length)
          : body.length;
      const sectionBody = body.slice(sectionStart, sectionEnd).trim();
      const items = sectionBody
        .split("\n")
        .filter((line) => line.startsWith("- "))
        .map((line) => line.slice(2));

      if (items.length > 0) sections.push({ title, items });
    }

    releases.push({ version, date, sections });
  }

  return releases;
}

const releases = parseChangelog(changelogSource);

function formatDate(date: string) {
  return new Date(`${date}T00:00:00Z`).toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  });
}
---

<Layout
  title="Changelog — Quire"
  description="A complete history of every Quire release derived from the canonical changelog."
>
  <div class="font-body bg-white text-primary min-h-screen" transition:animate={contentSlide}>
    <Nav base={base} />

    <section class="px-6 md:px-16 lg:px-24 pt-24 pb-16 border-b border-border">
      <div class="max-w-7xl mx-auto">
        <p class="text-xs font-light text-muted uppercase tracking-[0.2em] mb-4 animate-on-scroll">
          History
        </p>
        <h1
          class="font-display text-[clamp(3rem,7vw,6rem)] leading-[0.9] text-primary animate-on-scroll stagger-1"
        >
          Changelog.
        </h1>
      </div>
    </section>

    <section class="px-6 md:px-16 lg:px-24 py-16">
      <div class="max-w-7xl mx-auto border-t-2 border-primary">
        {
          releases.map((release, i) => (
            <article
              class:list={[
                "grid grid-cols-1 md:grid-cols-[10rem_1fr] gap-4 md:gap-8 py-8 border-b animate-on-scroll",
                i === releases.length - 1 ? "border-primary border-b-2" : "border-border",
                `stagger-${Math.min(i + 1, 8)}`,
              ]}
            >
              <div>
                <p class="font-display text-2xl text-primary">{release.version}</p>
                <p class="text-xs text-muted font-light mt-1">{formatDate(release.date)}</p>
              </div>
              <div class="space-y-5">
                {release.sections.map((section) => (
                  <section>
                    <h2 class="text-xs uppercase tracking-[0.18em] text-muted font-semibold mb-3">
                      {section.title}
                    </h2>
                    <ul class="space-y-2">
                      {section.items.map((item) => (
                        <li class="text-body font-light leading-relaxed">{item}</li>
                      ))}
                    </ul>
                  </section>
                ))}
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <Footer base={base} />
  </div>
</Layout>
