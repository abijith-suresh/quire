---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import Nav from "../../components/shared/Nav.astro";
import Footer from "../../components/shared/Footer.astro";
import { contentSlide } from "../../utils/transitions";

const base = import.meta.env.BASE_URL;

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout
  title="Blog — Pasta"
  description="Notes on design, privacy, and the craft of building client-side PDF tools. Updates from the Pasta team."
>
  <div class="font-body bg-white text-primary min-h-screen" transition:animate={contentSlide}>
    <Nav base={base} currentPage="blog" />

    <section class="px-6 md:px-16 lg:px-24 pt-24 pb-16 border-b border-border">
      <div class="max-w-7xl mx-auto">
        <p class="text-xs font-light text-muted uppercase tracking-[0.2em] mb-4 animate-on-scroll">
          Journal
        </p>
        <h1
          class="font-display text-[clamp(3rem,7vw,6rem)] leading-[0.9] text-primary animate-on-scroll stagger-1"
        >
          Notes.
        </h1>
      </div>
    </section>

    <section class="px-6 md:px-16 lg:px-24 py-16">
      <div class="max-w-7xl mx-auto border-t-2 border-primary">
        {
          posts.map((post, i) => (
            <a
              href={`${base}blog/${post.id}/`}
              class:list={[
                "grid grid-cols-1 md:grid-cols-[10rem_1fr] gap-2 md:gap-8 py-8 border-b animate-on-scroll group",
                i === posts.length - 1 ? "border-primary border-b-2" : "border-border",
                `stagger-${Math.min(i + 1, 8)}`,
              ]}
            >
              <div>
                <p class="text-xs text-muted font-light">
                  {post.data.date.toLocaleDateString("en-US", { month: "short", year: "numeric" })}
                </p>
                <p class="text-[0.65rem] uppercase tracking-[0.15em] text-accent font-medium mt-1">
                  {post.data.label}
                </p>
              </div>
              <div>
                <h2 class="font-display text-2xl text-primary mb-2 group-hover:text-accent transition-colors duration-150">
                  {post.data.title}
                </h2>
                <p class="text-body font-light leading-relaxed">{post.data.description}</p>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <Footer base={base} />
  </div>
</Layout>
