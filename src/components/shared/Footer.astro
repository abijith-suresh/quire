---
interface Props {
  base: string;
}

const { base } = Astro.props;
---

<footer
  class="border-t-2 border-primary px-6 md:px-16 lg:px-24 pt-16 pb-8"
  transition:animate="fade"
>
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-12">
      <div>
        <span class="font-display text-2xl text-primary">Pasta</span>
        <p class="text-sm font-light text-muted mt-2">
          Client-side PDF editing.<br />No uploads. No servers.
        </p>
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-8">
        <div>
          <p class="text-[0.65rem] uppercase tracking-[0.2em] text-muted mb-3">Product</p>
          <a
            href={`${base}features`}
            class="block text-sm text-body no-underline hover:text-primary transition-colors mb-2 link-slide"
            >Features</a
          >
          <a
            href={`${base}app`}
            class="block text-sm text-body no-underline hover:text-primary transition-colors mb-2 link-slide"
            >Open Editor</a
          >
          <a
            href={`${base}changelog`}
            class="block text-sm text-body no-underline hover:text-primary transition-colors mb-2 link-slide"
            >Changelog</a
          >
        </div>
        <div>
          <p class="text-[0.65rem] uppercase tracking-[0.2em] text-muted mb-3">Company</p>
          <a
            href={`${base}about`}
            class="block text-sm text-body no-underline hover:text-primary transition-colors mb-2 link-slide"
            >About</a
          >
          <a
            href={`${base}blog`}
            class="block text-sm text-body no-underline hover:text-primary transition-colors mb-2 link-slide"
            >Blog</a
          >
        </div>
        <div>
          <p class="text-[0.65rem] uppercase tracking-[0.2em] text-muted mb-3">Legal</p>
          <a
            href={`${base}privacy`}
            class="block text-sm text-body no-underline hover:text-primary transition-colors mb-2 link-slide"
            >Privacy</a
          >
          <a
            href={`${base}terms`}
            class="block text-sm text-body no-underline hover:text-primary transition-colors mb-2 link-slide"
            >Terms</a
          >
          <a
            href={`${base}faq`}
            class="block text-sm text-body no-underline hover:text-primary transition-colors mb-2 link-slide"
            >FAQ</a
          >
        </div>
      </div>
    </div>
    <div class="border-t border-border mt-12 pt-6 flex justify-between text-[0.65rem] text-muted">
      <span>&copy; 2026 Pasta</span>
      <a
        href="https://github.com/abijith-suresh/pasta"
        target="_blank"
        rel="noopener"
        class="text-muted no-underline hover:text-primary transition-colors link-slide">GitHub</a
      >
    </div>
  </div>
</footer>
