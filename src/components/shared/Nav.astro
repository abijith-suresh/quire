---
interface Props {
  base: string;
  currentPage?: string;
}

const { base, currentPage } = Astro.props;

const links = [
  { label: "Features", href: `${base}features`, key: "features" },
  { label: "About", href: `${base}about`, key: "about" },
  { label: "Blog", href: `${base}blog`, key: "blog" },
  { label: "FAQ", href: `${base}faq`, key: "faq" },
];
---

<nav class="border-b border-border px-6 md:px-16 lg:px-24" transition:persist>
  <div class="max-w-7xl mx-auto h-14 flex items-center justify-between">
    <a href={base} class="font-display text-2xl text-primary no-underline tracking-wide">Pasta</a>
    <div class="flex items-center gap-6 md:gap-8">
      {
        links.map((link) => (
          <a
            href={link.href}
            class:list={[
              "hidden sm:inline text-[0.65rem] font-medium text-body uppercase tracking-[0.15em] no-underline transition-colors hover:text-primary link-slide",
              currentPage === link.key && "text-primary border-b-2 border-primary pb-0.5",
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href={`${base}app`}
        class="text-[0.65rem] font-semibold uppercase tracking-[0.15em] text-white bg-accent hover:bg-primary px-5 py-2 no-underline transition-colors press-feedback"
      >
        Open Editor
      </a>
    </div>
  </div>
</nav>
