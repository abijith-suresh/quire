---
import { ViewTransitions } from "astro:transitions";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const base = import.meta.env.BASE_URL;
const siteOrigin = Astro.site?.toString().replace(/\/$/, "") ?? "";
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const slug = Astro.url.pathname.replace(base, "").replace(/\/$/, "") || "index";
const resolvedOgImage = ogImage ?? `${siteOrigin}${base}og/${slug}.png`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" href={`${base}favicon.ico`} />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Work+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
    <link rel="canonical" href={canonicalURL} />
    {description && <meta name="description" content={description} />}
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Quire" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={resolvedOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={resolvedOgImage} />
    <slot name="head" />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body>
    <slot />
    <script>
      import "../scripts/scroll-animations";
    </script>
  </body>
</html>
